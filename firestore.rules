// ============================================================
// TORITA Firestore Security Rules
// 設計書 v6 (DESIGN.md セクション 3-3) 準拠
// 作成: 2026/5/13 (Phase A-step1-1)
// 修正: 2026/5/14 (Phase A-step2) isSalonStaff を owner固定方式に変更
//
// 設計方針:
//   - Rules は「最低限の関所」
//   - 認証チェック、フィールドホワイトリスト、型チェック、単純な値域チェックのみ
//   - 複雑なロジック（営業時間、重複、価格計算）は Cloud Functions の責任
//   - フィールドホワイトリストで顧客の不正書き込みを防ぐ
//
// 2026/5/14 変更点:
//   - isSalonStaff() を exists() ベースから isSalonOwner() 代用に変更
//   - 理由: staffs ドキュメントID を owner固定方式に統一したため、
//     exists(.../staffs/{Auth UID}) は永遠に false になっていた
//   - フェーズ1はスタッフ=オーナー1人なので isSalonStaff == isSalonOwner で正しい
//   - フェーズ2で複数スタッフ対応時に exists() 版へ戻す（DESIGN_NOTES 段階移行方針）
//
// 2026/5/15 変更点 (その1):
//   - menus のホワイトリストに sortOrder を追加（int >= 0、省略可）
//   - 理由: メニュー設定画面で上下ボタンによる並び替えを実装するため
//   - shared_db_menu.js が sortOrder の付与と入れ替えを担当
//
// 2026/5/15 変更点 (その2):
//   - appointments の作成ルールを 2 経路に拡張:
//     (A) 顧客の pendingCreate=true 予約 (既存、source='online' 追加可)
//     (B) サロンスタッフの手動登録 (新規、status='confirmed', source='manual')
//   - 旧 TORITA の「＋登録」ボタン相当の手動登録を新TORITAでも可能に
//   - update ルールに source 改ざん禁止を追加
//   - intervalAfterOverride フィールドを許可 (予約ごとのインターバル個別調整)
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // ヘルパー関数
    // ============================================================
    
    // ログイン済みか
    function isSignedIn() {
      return request.auth != null;
    }
    
    // サロンオーナー本人か（Auth UID == salonId）
    function isSalonOwner(salonId) {
      return isSignedIn() && request.auth.uid == salonId;
    }
    
    // サロンに所属するスタッフか
    // ------------------------------------------------------------
    // 【2026/5/14 修正】owner固定方式に統一
    //   フェーズ1: staffs/owner の1ドキュメントだけ存在し、
    //              そのオーナー = salonId 本人。
    //              よって「スタッフか」は「オーナー本人か」と同値。
    //   フェーズ2: 複数スタッフ対応時、ここを下記の exists() 版に戻す:
    //     return isSignedIn() &&
    //       exists(/databases/$(database)/documents/salons/$(salonId)/staffs/$(request.auth.uid));
    //   （staffs/{各スタッフのAuth UID} ドキュメントが増える前提）
    // ------------------------------------------------------------
    function isSalonStaff(salonId) {
      return isSalonOwner(salonId);
    }
    
    // ============================================================
    // /salons/{salonId}
    // ============================================================
    
    match /salons/{salonId} {
      // サロン情報（info）
      // 読み取り: ログイン済みなら誰でも（顧客アプリでサロン名表示用）
      // 書き込み: オーナー本人のみ
      allow read: if isSignedIn();
      
      allow create: if isSalonOwner(salonId) &&
                      request.resource.data.keys().hasOnly([
                        'name', 'email', 'phone', 'address',
                        'createdAt', 'plan'
                      ]) &&
                      request.resource.data.keys().hasAll(['name', 'email', 'createdAt']) &&
                      request.resource.data.email is string &&
                      request.resource.data.name is string;
      
      allow update: if isSalonOwner(salonId) &&
                      // email は変更不可（Auth と整合性を保つ）
                      request.resource.data.email == resource.data.email;
      
      allow delete: if false;  // サロン削除は Functions 経由のみ（関連データ整理が必要）
      
      // ============================================================
      // /salons/{salonId}/staffs/{staffId}
      // フェーズ1: staffs/owner の1つだけ
      // ============================================================
      
      match /staffs/{staffId} {
        // 読み取り: オーナー or スタッフ本人
        allow read: if isSalonOwner(salonId) || 
                      (isSignedIn() && request.auth.uid == staffId);
        
        // 作成: オーナー本人が自分のスタッフドキュメントを作成（owner として）
        //       または、オーナーが他スタッフを追加（フェーズ2）
        allow create: if isSalonOwner(salonId) &&
                        request.resource.data.keys().hasOnly([
                          'name', 'role', 'email', 'active', 'createdAt'
                        ]) &&
                        request.resource.data.keys().hasAll(['name', 'role', 'active']) &&
                        request.resource.data.role in ['owner', 'staff'] &&
                        request.resource.data.active is bool;
        
        allow update: if isSalonOwner(salonId);
        allow delete: if isSalonOwner(salonId) && staffId != 'owner';  // owner は削除不可
      }
      
      // ============================================================
      // /salons/{salonId}/resources/{resourceId}
      // フェーズ1: resources/default の1つだけ
      // ============================================================
      
      match /resources/{resourceId} {
        // 読み取り: ログイン済みなら誰でも（予約可能時間計算で必要）
        allow read: if isSignedIn();
        
        allow create: if isSalonOwner(salonId) &&
                        request.resource.data.keys().hasOnly([
                          'name', 'type', 'active', 'createdAt'
                        ]) &&
                        request.resource.data.keys().hasAll(['name', 'active']) &&
                        request.resource.data.active is bool;
        
        allow update: if isSalonOwner(salonId);
        allow delete: if isSalonOwner(salonId) && resourceId != 'default';  // default は削除不可
      }
      
      // ============================================================
      // /salons/{salonId}/shifts/{shiftId}
      // フェーズ1: 使わない（営業時間 = オーナーのシフト扱い）
      // フェーズ2で本格利用
      // ============================================================
      
      match /shifts/{shiftId} {
        allow read: if isSalonStaff(salonId);
        allow write: if isSalonOwner(salonId);
      }
      
      // ============================================================
      // /salons/{salonId}/menus/{menuId}
      // ============================================================
      
      match /menus/{menuId} {
        // 読み取り: public=true は誰でも、public=false はスタッフのみ
        allow read: if isSignedIn() && 
                      (resource.data.public == true || isSalonStaff(salonId));
        
        // 作成: スタッフのみ、フィールド検証
        // ★ v8.1: intervalBefore/intervalAfter は廃止。
        //   インターバルは settings.intervalMin（サロン共通設定）に1本化
        allow create: if isSalonStaff(salonId) &&
                        request.resource.data.keys().hasOnly([
                          'name', 'duration', 'price', 'type', 'public',
                          'eligibleStaffIds', 'requiredResourceIds',
                          'description', 'contraindications',
                          'photoUrl', 'sortOrder', 'createdAt'
                        ]) &&
                        request.resource.data.keys().hasAll([
                          'name', 'duration', 'price', 'type', 'public',
                          'eligibleStaffIds', 'requiredResourceIds'
                        ]) &&
                        request.resource.data.name is string &&
                        request.resource.data.duration is int &&
                        request.resource.data.duration > 0 &&
                        request.resource.data.price is int &&
                        request.resource.data.price >= 0 &&
                        request.resource.data.type in ['main', 'option'] &&
                        request.resource.data.public is bool &&
                        request.resource.data.eligibleStaffIds is list &&
                        request.resource.data.requiredResourceIds is list &&
                        (!('sortOrder' in request.resource.data) ||
                          (request.resource.data.sortOrder is int &&
                           request.resource.data.sortOrder >= 0));
        
        allow update: if isSalonStaff(salonId);
        allow delete: if isSalonOwner(salonId);
      }
      
      // ============================================================
      // /salons/{salonId}/customers/{customerDocId}
      // ★ v8.1 改訂（DESIGN.md 3-3 / DESIGN_v8_1 4-1 と1対1照合）
      //   customerDocId = Firestore 採番。本人判定は
      //   resource.data.authUid == request.auth.uid（uid 直比較でない）
      // ============================================================
      match /customers/{customerDocId} {
        // 読み取り: サロンスタッフ全員 / 本人（authUid 一致）
        allow read: if isSalonStaff(salonId)
                    || (isSignedIn() &&
                        resource.data.authUid == request.auth.uid);

        // 作成: サロンスタッフによる仮登録のみ許可。
        //   顧客self経路は廃止（2026/5/30）。
        //   正規ルートは resolveOrClaimCustomer Function（Admin SDK）経由。
        //   Admin SDK は Rules をバイパスするため claim には影響しない。
        allow create: if
          ( isSalonStaff(salonId) &&
            request.resource.data.authUid == null &&
            request.resource.data.createdSource == 'salon' &&
            request.resource.data.keys().hasOnly([
              'name','phone','email','authUid','createdSource',
              'notifyChannels','isMerged','mergedInto','mergedAt',
              'mergedAliases','createdAt'
            ]) );

        // 更新: 顧客本人は name/phone/notifyChannels のみ。
        //   サロンは memo/stampCount 等可。ただし authUid/merge系/
        //   createdSource/lockedByJob/lineUserId/needsMergeReview は
        //   クライアント不可（Function=admin のみ。
        //   source of truth・排他制御・重複検知ロジックの要）
        //   ★ v6.1（2026/5/25）：needsMergeReview を禁止リストに追加
        allow update: if
          ( isSignedIn() &&
            resource.data.authUid == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['name','phone','notifyChannels','updatedAt']) )
          ||
          ( isSalonStaff(salonId) &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['lineUserId','authUid','isMerged','mergedInto',
                       'mergedAt','mergedAliases','createdSource',
                       'lockedByJob','needsMergeReview']) );

        // 削除: 物理削除はオーナーのみ（通常運用は soft delete）
        allow delete: if isSalonOwner(salonId);
      }

      // ============================================================
      // /salons/{salonId}/authIndex/{authUid}
      // ★ v8.1 新規：逆引きインデックス（source of truth）
      //   claim/merge は Function(admin) が書く＝一元管理
      // ============================================================
      match /authIndex/{authUid} {
        allow read:  if (isSignedIn() && authUid == request.auth.uid)
                     || isSalonStaff(salonId);
        allow write: if false;  // Function(admin) のみ
      }

      // ============================================================
      // /salons/{salonId}/mergeJobs/{jobId}
      // ★ v8.1 新規：merge ジョブ（排他制御・進捗管理）
      // ============================================================
      match /mergeJobs/{jobId} {
        allow read:  if isSalonStaff(salonId);  // UIが進捗表示に使う
        allow write: if false;                  // Function(admin) のみ
      }
      
      // ============================================================
      // /salons/{salonId}/appointments/{appointmentId}
      // 設計書 v6 セクション 3-4 の pendingCreate 方式
      // ============================================================
      
      // ============================================================
      // /salons/{salonId}/appointments/{appointmentId}
      // ★ v8.1 改訂（DESIGN.md 3-3 と1対1照合）
      //   customerId→customerDocId 改名。本人判定は
      //   resource.data.authUid == request.auth.uid
      //   作成は (A)顧客アプリ予約 / (B)サロン手動登録 の2経路
      // ============================================================
      match /appointments/{appointmentId} {
        // 読み取り: サロンスタッフ or 予約本人（authUid 一致）
        allow read: if isSalonStaff(salonId) ||
                      (isSignedIn() &&
                       resource.data.authUid == request.auth.uid);

        allow create: if (
          // ── (A) 顧客アプリ予約（pendingCreate=true）──
          (isSignedIn() &&
           exists(/databases/$(database)/documents/salons/$(salonId)) &&
           request.resource.data.authUid == request.auth.uid &&
           request.resource.data.keys().hasOnly([
             'dateKey', 'start', 'customerDocId', 'authUid',
             'menuId', 'optionMenuIds', 'pendingCreate',
             'source', 'createdAt'
           ]) &&
           request.resource.data.keys().hasAll([
             'dateKey', 'start', 'customerDocId',
             'authUid', 'menuId', 'pendingCreate'
           ]) &&
           request.resource.data.pendingCreate == true &&
           (!('source' in request.resource.data) ||
             request.resource.data.source == 'online') &&
           request.resource.data.dateKey is string &&
           request.resource.data.dateKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
           request.resource.data.start is string &&
           request.resource.data.start.matches('^[0-9]{2}:[0-9]{2}$') &&
           request.resource.data.menuId is string &&
           (!('optionMenuIds' in request.resource.data) ||
             request.resource.data.optionMenuIds is list))
          ||
          // ── (B) サロン手動登録（電話・店頭予約、最初から確定）──
          //   対象がサロン仮登録カルテなら authUid=null。後でその
          //   顧客がアプリ登録(claim)した時、claim Function が
          //   この予約の authUid を後埋めする（DESIGN_v8_1 2-4）
          (isSalonStaff(salonId) &&
           request.resource.data.customerDocId is string &&
           request.resource.data.keys().hasOnly([
             'dateKey', 'start', 'end',
             'startAt', 'endAt',
             'customerDocId', 'authUid', 'customerSnapshot',
             'menuId', 'menuNameSnapshot', 'optionMenuIds',
             'staffId', 'resourceIds',
             'status', 'source',
             'priceSnapshot', 'durationMin',
             'intervalAfterOverride',
             'memo', 'editingBy',
             'createdAt', 'updatedAt'
           ]) &&
           request.resource.data.keys().hasAll([
             'dateKey', 'start',
             'customerDocId', 'menuId', 'status', 'source'
           ]) &&
           request.resource.data.source == 'manual' &&
           request.resource.data.status == 'confirmed' &&
           request.resource.data.dateKey is string &&
           request.resource.data.dateKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
           request.resource.data.start is string &&
           request.resource.data.start.matches('^[0-9]{2}:[0-9]{2}$') &&
           (!('end' in request.resource.data) ||
             (request.resource.data.end is string &&
              request.resource.data.end.matches('^[0-9]{2}:[0-9]{2}$'))) &&
           request.resource.data.menuId is string &&
           (!('optionMenuIds' in request.resource.data) ||
             request.resource.data.optionMenuIds is list) &&
           (!('intervalAfterOverride' in request.resource.data) ||
             (request.resource.data.intervalAfterOverride is int &&
              request.resource.data.intervalAfterOverride >= 0)))
        );

        // 更新:
        //  - 顧客は自分の予約を confirmed → cancelled にのみ
        //  - サロンは customerDocId/source 改ざん以外は可能
        //  - 詳細な status 遷移は Cloud Functions の責任
        //  - merge による customerDocId 付替は Function=admin のみ
        //  ★ カルテ機能(v8.1+): サロンスタッフは下記フィールドを追加・更新可
        //    - payment (int >= 0)        実支払い金額
        //    - visitMemo (string)        訪問メモ（施術内容・申し送り）
        //    - photos (list, 最大3要素)  施術前後の写真 [{id,path,url,time}]
        //    顧客アプリからはこれらを書けない（顧客の更新は status のみ）
        allow update: if (
          (isSignedIn() &&
           resource.data.authUid == request.auth.uid &&
           resource.data.status == 'confirmed' &&
           request.resource.data.status == 'cancelled' &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt']))
          ||
          (isSalonStaff(salonId) &&
           request.resource.data.customerDocId == resource.data.customerDocId &&
           request.resource.data.source == resource.data.source)
        );

        // 削除: オーナーのみ（通常は status=cancelled でソフト削除）
        allow delete: if isSalonOwner(salonId);
      }
      // ============================================================
      // /salons/{salonId}/appointments_archive/{appointmentId}
      // 18ヶ月以上前の予約。クライアントからは読み取り専用
      // ============================================================
      
      match /appointments_archive/{appointmentId} {
        // ★ v8.1：本人判定は authUid 一致
        allow read: if isSalonStaff(salonId) ||
                      (isSignedIn() &&
                       resource.data.authUid == request.auth.uid);
        // 作成・更新・削除は Cloud Functions のみ
        allow write: if false;
      }
      
      // ============================================================
      // /salons/{salonId}/closeBlocks/{blockId}
      // 臨時休業・営業時間外ブロック
      // ============================================================
      
      match /closeBlocks/{blockId} {
        allow read: if isSignedIn();  // 予約可能時間計算で必要
        allow write: if isSalonStaff(salonId);
      }
      
      // ============================================================
      // /salons/{salonId}/config/{configId}
      // settings, cancelPolicy, stampCard など
      // ============================================================
      
      match /config/{configId} {
        allow read: if isSignedIn();
        allow write: if isSalonStaff(salonId);
      }
      
      // ============================================================
      // /salons/{salonId}/notificationLogs/{logId}
      // 通知失敗ログ。Cloud Functions のみ書き込み、スタッフは読み取り可
      // ============================================================
      
      match /notificationLogs/{logId} {
        allow read: if isSalonStaff(salonId);
        allow write: if false;  // Functions のみ
      }
    }
    
    // ============================================================
    // 上記以外のすべてのパスを拒否（明示的に許可されていないものは禁止）
    // ============================================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
